# X-Lang Bazel Configuration (Bazel 9.0+)
# See https://bazel.build/docs/bazelrc

# Build options
build --color=yes
build --curses=yes
build --verbose_failures
build --experimental_convenience_symlinks=ignore

# Enable Bzlmod (Bazel 9.0+ 默认启用)
common --enable_bzlmod

# Rust options
build --@rules_rust//rust/settings:pipeline_deps=true

# Enable color output
test --color=yes
test --test_output=errors
test --verbose_failures

# Default to release mode for performance
# build --compilation_mode=opt

# Keep debug info for debugging
build --strip=never

# Disk cache (uncomment and set path to enable)
# build --disk_cache=~/.cache/bazel/disk

# Remote cache (uncomment and configure to enable)
# build --remote_cache=grpc://your-cache-server:8980

# Windows-specific settings
build --enable_runfiles
