let a = 42
let b: integer = 100
let c = 3.14159
let d: string = "Hello, X!"
let e = true
let f: boolean = false

println("Integer: " + a)
println("Explicit integer: " + b)
println("Float: " + c)
println("String: " + d)
println("Boolean: " + e)
println("Boolean: " + f)

let mutable counter = 0
counter = counter + 1
counter += 10
println("Mutable counter: " + counter)

let greeting: string = "Hello"
let name: string = "X Language"
let message = greeting + ", " + name + "!"
println(message)
