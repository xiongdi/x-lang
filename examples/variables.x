// 变量和数据类型示例

// 不可变变量 (val)
val message = "Hello, X Language!"
print(message)

// 可变变量 (var)
var count = 0
count = count + 1
print("Count: " + count)

// 基本数据类型
val integer = 42
val floating = 3.14159
val boolean = true
val character = 'X'

print("Integer: " + integer)
print("Float: " + floating)
print("Boolean: " + boolean)
print("Char: " + character)

// 多变量声明
val a = 10, b = 20
print("a + b = " + (a + b))
