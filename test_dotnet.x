let x = 5
let y = 10

println("x = " + x)
println("y = " + y)
println("sum = " + (x + y))
println("difference = " + (x - y))
println("product = " + (x * y))
println("quotient = " + (y / x))

if x < y {
    println("x is less than y")
} else {
    println("x is greater than or equal to y")
}

println("Counting from 1 to 5:")
let i = 1
while i <= 5 {
    println(i)
    i = i + 1
}
