// @test arithmetic operations

let a = 10 + 32
let b = 10 - 2
let c = 3 * 5
let d = 15 / 5
let e = 10 % 3

println("a: " + a)
println("b: " + b)
println("c: " + c)
println("d: " + d)
println("e: " + e)

let x = 2 + 3 * 4
let y = (2 + 3) * 4
println("x: " + x)
println("y: " + y)

let neg = -5
println("neg: " + neg)

let f = 3.14 + 2.86
println("f: " + f)
