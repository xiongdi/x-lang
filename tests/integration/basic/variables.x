// @test variable declarations and scoping

let x = 42
println("x: " + x)

let y: integer = 100
println("y: " + y)

let mutable counter = 0
counter = counter + 1
counter = counter + 1
println("counter: " + counter)

let name = "X Language"
let version = 1.0
let active = true

println("name: " + name)
println("version: " + version)
println("active: " + active)
