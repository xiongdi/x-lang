{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "X",
  "scopeName": "source.x",
  "fileTypes": ["x"],
  "patterns": [
    {
      "name": "keyword.control",
      "match": "\b(needs|given|wait|when|is|can|atomic|fn|func|function|let|var|const|if|else|while|for|loop|match|return|break|continue|struct|enum|type|impl|trait|use|mod|pub|mut|ref|self|Self|true|false|null|None|Some|Ok|Err)\b"
    },
    {
      "name": "storage.type",
      "match": "\b(int|i8|i16|i32|i64|isize|uint|u8|u16|u32|u64|usize|float|f32|f64|bool|string|char|void|never|any)\b"
    },
    {
      "name": "string.quoted.double",
      "match": "&quot;[^&quot;\\]*(\\.[^&quot;\\]*)*&quot;"
    },
    {
      "name": "string.quoted.single",
      "match": "&#x27;[^&#x27;\\]*(\\.[^&#x27;\\]*)*&#x27;"
    },
    {
      "name": "constant.character",
      "match": "&#x27;\\?.&#x27;"
    },
    {
      "name": "constant.numeric",
      "match": "\b[0-9]+(\.[0-9]+)?([eE][+-]?[0-9]+)?\b"
    },
    {
      "name": "constant.language.boolean",
      "match": "\b(true|false)\b"
    },
    {
      "name": "comment.line.double-slash",
      "match": "//.*$"
    },
    {
      "name": "comment.block",
      "match": "/\*[\s\S]*?\*/"
    },
    {
      "name": "variable.other",
      "match": "\b[a-zA-Z_][a-zA-Z0-9_]*\b"
    },
    {
      "name": "keyword.operator",
      "match": "(\+\|\-\|\*\|/\|%\|&#x3D;\|\+&#x3D;\|\-&#x3D;\|\*&#x3D;\|/&#x3D;\|%&#x3D;\|&#x3D;&#x3D;\|!&#x3D;\|&lt;\|&gt;\|&lt;&#x3D;\|&gt;&#x3D;\|\&amp;\&amp;\|\|\|\|!\|\~\|\&amp;\|\|\|\^\|&lt;&lt;\|&gt;&gt;\|\-&gt;\|&#x3D;&gt;\|::\|\.\|\.\.\|\.\.\.)"
    },
    {
      "name": "punctuation",
      "match": "[{}()\[\],;:.]"
    },
    {
      "name": "support.function",
      "match": "\b(print|println|dbg|panic|assert|assert_eq|len|push|pop|insert|remove|get|set|parse|to_string|to_int|to_float)\b"
    }
  ],
  "repository": {}
}
